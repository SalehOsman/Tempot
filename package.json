{
  "name": "tempot-monorepo",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter bot-server dev",
    "build": "pnpm --recursive build",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose --project=unit",
    "test:integration": "vitest run --reporter=verbose --project=integration",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky",
    "docker:dev": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "cms:check": "pnpm --filter @tempot/i18n-core cms:check",
    "spec:validate": "npx tsx scripts/spec-validate/index.ts"
  },
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.0",
    "@tempot/database": "workspace:*",
    "@tempot/event-bus": "workspace:*",
    "@tempot/logger": "workspace:*",
    "@tempot/session-manager": "workspace:*",
    "@tempot/shared": "workspace:*",
    "@vitest/coverage-v8": "^4.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-check-file": "^3.3.1",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "prisma": "^7.5.0",
    "tslib": "^2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "4.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
