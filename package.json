{
  "name": "tempot-monorepo",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter bot-server dev",
    "tempot": "tsx scripts/tempot/index.ts",
    "dev:tunnel": "pnpm --filter bot-server dev:tunnel",
    "webhook:set": "pnpm --filter bot-server webhook:set",
    "webhook:info": "pnpm --filter bot-server webhook:info",
    "webhook:delete": "pnpm --filter bot-server webhook:delete",
    "build": "pnpm --recursive build",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose --project=unit",
    "test:integration": "vitest run --reporter=verbose --project=integration",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky",
    "docker:dev": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "cms:check": "pnpm --filter @tempot/i18n-core cms:check",
    "spec:validate": "tsx scripts/spec-validate/index.ts --all",
    "spec:validate:one": "tsx scripts/spec-validate/index.ts",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version"
  },
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "vitest>vite": "^8.0.8",
      "astro>vite": "^8.0.8",
      "astro>esbuild": "^0.27.0",
      "@esbuild-kit/core-utils>esbuild": "^0.25.12",
      "@prisma/dev>@hono/node-server": "^1.19.13",
      "dockerode>uuid": "^14.0.0",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.0",
    "@tempot/database": "workspace:*",
    "@tempot/event-bus": "workspace:*",
    "@tempot/logger": "workspace:*",
    "@tempot/session-manager": "workspace:*",
    "@tempot/shared": "workspace:*",
    "@types/node": "22.19.17",
    "@vitest/coverage-v8": "^4.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-check-file": "^3.3.1",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "prisma": "^7.8.0",
    "tslib": "^2.8.1",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "4.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
