{
  "name": "tempot-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "corepack pnpm --filter bot-server dev",
    "build:bot-runtime": "corepack pnpm --recursive --filter bot-server... --filter @tempot/input-engine... --filter @tempot/interaction-observability... --filter @tempot/ux-helpers... --filter @tempot/bot-management... --filter @tempot/template-management... --filter @tempot/user-management... --filter @tempot/settings-management... --filter @tempot/notification-center... --filter @tempot/content-management... --filter @tempot/audit-viewer... --filter @tempot/help-center... build",
    "dev:bot": "corepack pnpm build:bot-runtime && corepack pnpm --parallel --stream --filter @tempot/input-engine --filter @tempot/interaction-observability --filter @tempot/ux-helpers --filter @tempot/bot-management --filter @tempot/template-management --filter @tempot/user-management --filter @tempot/settings-management --filter @tempot/notification-center --filter @tempot/content-management --filter @tempot/audit-viewer --filter @tempot/help-center --filter bot-server dev:watch",
    "tempot": "tsx scripts/tempot/index.ts",
    "dev:tunnel": "corepack pnpm --filter bot-server dev:tunnel",
    "webhook:set": "corepack pnpm --filter bot-server webhook:set",
    "webhook:info": "corepack pnpm --filter bot-server webhook:info",
    "webhook:delete": "corepack pnpm --filter bot-server webhook:delete",
    "build": "corepack pnpm --recursive build",
    "test": "corepack pnpm test:inventory && vitest run --reporter=verbose",
    "test:all": "corepack pnpm test",
    "test:inventory": "tsx scripts/ci/test-project-inventory.ts",
    "test:unit": "vitest run --reporter=verbose --project=unit --project=application",
    "test:integration": "vitest run --reporter=verbose --project=integration",
    "test:e2e": "vitest run --reporter=verbose --project=e2e",
    "test:coverage": "vitest run --coverage --reporter=verbose && tsx scripts/ci/coverage-policy.ts coverage/coverage-summary.json",
    "lint": "eslint .",
    "boundary:audit": "tsx scripts/ci/import-boundary-audit.cli.ts",
    "authorization:check": "tsx scripts/ci/authorization-coverage-audit.ts",
    "module:checklist": "tsx scripts/ci/module-package-checklist-audit.ts",
    "source:conformance": "tsx scripts/ci/source-conformance-audit.ts",
    "toolchain:audit": "tsx scripts/ci/toolchain-audit.ts",
    "security:inventory": "corepack pnpm --filter @tempot/database db:generate && corepack pnpm --recursive --filter @tempot/database... build && tsx scripts/security/sensitive-data-inventory.cli.ts",
    "docs:freshness": "corepack pnpm --filter docs docs:freshness",
    "docs:validate": "corepack pnpm --filter docs docs:validate",
    "docs:claims": "tsx scripts/ci/documentation-claims-audit.ts",
    "docs:check": "corepack pnpm docs:freshness && corepack pnpm docs:validate && corepack pnpm docs:claims",
    "format": "prettier --write .",
    "prepare": "husky",
    "docker:dev": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "cms:check": "corepack pnpm --filter @tempot/i18n-core cms:check",
    "spec:validate": "tsx scripts/spec-validate/index.ts --all",
    "spec:validate:one": "tsx scripts/spec-validate/index.ts",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version"
  },
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.0",
    "@tempot/database": "workspace:*",
    "@tempot/event-bus": "workspace:*",
    "@tempot/logger": "workspace:*",
    "@tempot/session-manager": "workspace:*",
    "@tempot/shared": "workspace:*",
    "@types/node": "22.19.17",
    "@vitest/coverage-v8": "4.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-check-file": "^3.3.1",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "prisma": "^7.8.0",
    "tslib": "^2.8.1",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "4.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
