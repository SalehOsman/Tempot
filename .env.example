# =============================================================================
# Tempot - Environment Variables Reference
# =============================================================================
# Instructions:
#   1. Copy this file to .env.
#   2. Fill the required values for your local, staging, or production runtime.
#   3. Never commit .env because it contains secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Section 1 - Core System
# -----------------------------------------------------------------------------

# Telegram Bot token from @BotFather.
BOT_TOKEN=

# PostgreSQL connection string.
DATABASE_URL=

# Redis connection string.
REDIS_URL=

# Comma-separated Telegram user IDs that receive the SUPER_ADMIN role.
SUPER_ADMIN_IDS=

# Bot operation mode: polling or webhook.
BOT_MODE=

# Required when BOT_MODE is webhook.
WEBHOOK_URL=
WEBHOOK_SECRET_TOKEN=
TEMPOT_READINESS_TOKEN=

# Node runtime environment.
NODE_ENV=

# -----------------------------------------------------------------------------
# Section 2 - Internationalization and Region
# -----------------------------------------------------------------------------

# Primary language: ar or en.
DEFAULT_LANGUAGE=

# Default country using ISO 3166-1 alpha-2.
DEFAULT_COUNTRY=

# Regional mode: static or dynamic.
REGIONAL_MODE=

# -----------------------------------------------------------------------------
# Section 3 - AI Provider and Embeddings
# -----------------------------------------------------------------------------

# Legacy AI provider selector.
AI_PROVIDER=

# Runtime AI provider selector used by ai-core: gemini or openai.
TEMPOT_AI_PROVIDER=

# Embedding model. Changing this requires re-indexing existing embeddings.
AI_EMBEDDING_MODEL=

# Embedding vector dimensions. Must match AI_EMBEDDING_MODEL.
AI_EMBEDDING_DIMENSIONS=

# Gemini provider keys.
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenAI provider key.
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Section 4 - Pluggable Architecture Feature Flags
# -----------------------------------------------------------------------------

# Core packages.
TEMPOT_AUTH=
TEMPOT_SESSIONS=
TEMPOT_NOTIFIER=
TEMPOT_LOGGER=
TEMPOT_AUDIT=
TEMPOT_AI=
TEMPOT_PRIVACY=
TEMPOT_STORAGE=
TEMPOT_BACKUP=
TEMPOT_DASHBOARD=
TEMPOT_REGIONAL=

# Optional packages.
TEMPOT_INPUT=
TEMPOT_DYNAMIC_CMS=
TEMPOT_SEARCH=
TEMPOT_DOCUMENTS=
TEMPOT_IMPORT=
TEMPOT_MINI_APPS=
TEMPOT_SENTRY=
TEMPOT_PAYMENT=

# -----------------------------------------------------------------------------
# Section 5 - Observability
# -----------------------------------------------------------------------------

SENTRY_DSN=
LOG_LEVEL=

# -----------------------------------------------------------------------------
# Section 6 - Storage Engine
# -----------------------------------------------------------------------------

# Active storage provider: local, google-drive, or s3.
STORAGE_PROVIDER=

# Local storage path.
STORAGE_LOCAL_PATH=

# Google Drive storage.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# AWS S3 or S3-compatible storage.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# -----------------------------------------------------------------------------
# Section 7 - Payment Core
# -----------------------------------------------------------------------------

PAYMENT_PROVIDER_TELEGRAM=
PAYMENT_PROVIDER_STRIPE=
PAYMENT_PROVIDER_PAYPAL=

# Stripe.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Section 8 - Protected Data Encryption
# -----------------------------------------------------------------------------

PROTECTED_DATA_ACTIVE_ENCRYPTION_KEY_VERSION=
PROTECTED_DATA_ENCRYPTION_KEYS=
PROTECTED_DATA_ACTIVE_LOOKUP_KEY_VERSION=
PROTECTED_DATA_LOOKUP_KEYS=
