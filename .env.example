# =============================================================================
# Tempot — Environment Variables Reference
# Spec: docs/tempot_v11_final.md | Appendix C (all variables indexed here)
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in all required (*) values before running pnpm dev
#   3. Never commit .env to version control — it is in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SECTION 1 — Core System (Required — Section 11.1)
# -----------------------------------------------------------------------------

# * Telegram Bot Token — get from @BotFather
BOT_TOKEN=

# * PostgreSQL connection string
#   Local dev: matches docker-compose.yml defaults
DATABASE_URL=postgresql://tempot:tempot_password@localhost:5432/tempot_db

# * Redis connection string
#   Local dev: matches docker-compose.yml defaults
REDIS_URL=redis://localhost:6379

# * Comma-separated Telegram user IDs for SUPER_ADMIN role (Section 5.5)
#   No spaces. Example: 123456789,987654321
SUPER_ADMIN_IDS=

# Bot operation mode: polling (local dev) | webhook (production)
# See Section 25.4 for webhook transition guide
BOT_MODE=polling

# Required when BOT_MODE=webhook
WEBHOOK_URL=
# Auto-generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET_TOKEN=

# Node environment
NODE_ENV=development

# -----------------------------------------------------------------------------
# SECTION 2 — Internationalization & Region (Section 8.2, 11.3)
# -----------------------------------------------------------------------------

# Primary language: ar | en
DEFAULT_LANGUAGE=ar

# Default country — ISO 3166-1 alpha-2 (Section 11.3 — EG is the default)
DEFAULT_COUNTRY=EG

# Regional mode: static (one country for all) | dynamic (per-user)
REGIONAL_MODE=static

# -----------------------------------------------------------------------------
# SECTION 3 — AI Provider (Section 17.1.1)
# -----------------------------------------------------------------------------

# Active AI provider: gemini | openai | cohere
AI_PROVIDER=gemini

# Embedding model — CRITICAL: changing provider requires full re-indexing
# See docs/architecture/AI-REINDEXING-STRATEGY.md
AI_EMBEDDING_MODEL=gemini-embedding-2-preview

# Embedding vector dimensions — must match the model above
AI_EMBEDDING_DIMENSIONS=1536

# Gemini API key (required when AI_PROVIDER=gemini)
GEMINI_API_KEY=

# OpenAI API key (required when AI_PROVIDER=openai)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# SECTION 4 — Pluggable Architecture (Section 30 — all feature flags)
# -----------------------------------------------------------------------------
# true = package is loaded and active
# false = package is NOT loaded, no resources consumed

# --- Core packages (recommended: keep true) ---
TEMPOT_AUTH=true
TEMPOT_SESSIONS=true
TEMPOT_NOTIFIER=true
TEMPOT_LOGGER=true
TEMPOT_AUDIT=true
TEMPOT_AI=true
TEMPOT_PRIVACY=true
TEMPOT_STORAGE=true
TEMPOT_BACKUP=true
TEMPOT_DASHBOARD=true
TEMPOT_REGIONAL=true

# --- Optional packages (disabled by default) ---
TEMPOT_INPUT=false
TEMPOT_DYNAMIC_CMS=false
TEMPOT_SEARCH=false
TEMPOT_DOCUMENTS=false
TEMPOT_IMPORT=false
TEMPOT_MINI_APPS=false
TEMPOT_SENTRY=false
TEMPOT_PAYMENT=false

# -----------------------------------------------------------------------------
# SECTION 5 — Observability (Section 26)
# -----------------------------------------------------------------------------

# Sentry DSN — required when TEMPOT_SENTRY=true
# Self-hosted Sentry is supported
SENTRY_DSN=

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# SECTION 6 — Storage Engine (Section 19.1)
# -----------------------------------------------------------------------------

# Active storage provider: local | google-drive | s3
STORAGE_PROVIDER=local

# Local storage path (used when STORAGE_PROVIDER=local)
STORAGE_LOCAL_PATH=./uploads

# Google Drive (required when STORAGE_PROVIDER=google-drive)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# AWS S3 / S3-compatible (required when STORAGE_PROVIDER=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: override endpoint for S3-compatible providers (DigitalOcean, R2, etc.)
S3_ENDPOINT=

# -----------------------------------------------------------------------------
# SECTION 7 — Payment Core (Section 32 — requires TEMPOT_PAYMENT=true)
# -----------------------------------------------------------------------------

PAYMENT_PROVIDER_TELEGRAM=false
PAYMENT_PROVIDER_STRIPE=false
PAYMENT_PROVIDER_PAYPAL=false

# Stripe secret key (required when PAYMENT_PROVIDER_STRIPE=true)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal (required when PAYMENT_PROVIDER_PAYPAL=true)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
