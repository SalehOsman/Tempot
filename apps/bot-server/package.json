{
  "name": "bot-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "dev:tunnel": "cloudflared tunnel --url http://localhost:3000",
    "webhook:set": "tsx scripts/webhook-manager.ts set",
    "webhook:info": "tsx scripts/webhook-manager.ts info",
    "webhook:delete": "tsx scripts/webhook-manager.ts delete",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@casl/ability": "^6.7.3",
    "@tempot/auth-core": "workspace:*",
    "@tempot/database": "workspace:*",
    "@tempot/event-bus": "workspace:*",
    "@tempot/i18n-core": "workspace:*",
    "@tempot/input-engine": "workspace:*",
    "@tempot/logger": "workspace:*",
    "@tempot/module-registry": "workspace:*",
    "@tempot/regional-engine": "workspace:*",
    "@tempot/sentry": "workspace:*",
    "@tempot/session-manager": "workspace:*",
    "@tempot/settings": "workspace:*",
    "@tempot/shared": "workspace:*",
    "@tempot/ux-helpers": "workspace:*",
    "grammy": "^1.41.1",
    "hono": "^4.12.15",
    "neverthrow": "8.2.0",
    "rate-limiter-flexible": "^5.0.4",
    "sanitize-html": "^2.17.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sanitize-html": "^2.13.0",
    "tsx": "^4.0.0",
    "vitest": "4.1.0"
  }
}
