// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Global Audit Fields (Constitution Rule XXVII)
// These should be copied to every model that needs audit/soft-delete
// until Prisma supports native mixins or global fields.

// User Management Module - User Profile
model UserProfile {
  id         String  @id @default(cuid())
  telegramId BigInt  @unique
  username   String?
  email      String?
  language   String  @default("ar")
  role       String  @default("USER")

  // Additional identity fields
  nationalId                     String?   @unique
  mobileNumber                   String?
  birthDate                      DateTime?
  emailProtected                 Json?
  emailLookupToken               String?
  emailLookupKeyVersion          String?
  emailNormalizationVersion      String?
  nationalIdProtected            Json?
  nationalIdLookupToken          String?
  nationalIdLookupKeyVersion     String?
  nationalIdNormalizationVersion String?
  mobileNumberProtected          Json?
  birthDateProtected             Json?
  gender                         String? // 'male' | 'female'
  governorate                    String?
  countryCode                    String?   @default("+20")

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  @@index([telegramId])
  @@index([username])
  @@index([email])
  @@index([emailLookupToken])
  @@index([role])
  @@index([nationalId])
  @@index([nationalIdLookupToken])
  @@index([mobileNumber])
  @@index([isDeleted])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userRole  String?
  action    String
  module    String
  targetId  String?
  before    Json?
  after     Json?
  status    String   @default("SUCCESS")
  timestamp DateTime @default(now())

  @@index([module, action])
  @@index([userId])
}

model InteractionEvent {
  id                String   @id @default(cuid())
  traceId           String   @map("trace_id")
  sequence          Int
  updateId          Int?     @map("update_id")
  updateType        String   @map("update_type")
  command           String?
  callbackData      String?  @map("callback_data")
  callbackNamespace String?  @map("callback_namespace")
  module            String
  userId            String?  @map("user_id")
  chatId            String?  @map("chat_id")
  stage             String
  status            String
  action            String?
  viewKey           String?  @map("view_key")
  responseType      String?  @map("response_type")
  reason            String?
  errorCode         String?  @map("error_code")
  referenceCode     String?  @map("reference_code")
  metadata          Json?
  occurredAt        DateTime @default(now()) @map("occurred_at")

  // Audit fields
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@unique([traceId, sequence], map: "interaction_events_trace_sequence_key")
  @@index([traceId, sequence], map: "idx_interaction_events_trace_sequence")
  @@index([module, stage], map: "idx_interaction_events_module_stage")
  @@index([status, occurredAt], map: "idx_interaction_events_status_time")
  @@index([callbackNamespace], map: "idx_interaction_events_callback_namespace")
  @@index([isDeleted], map: "idx_interaction_events_deleted")
  @@map("interaction_events")
}

model Session {
  id                 String  @id // Composite of userId:chatId
  userId             String
  chatId             String
  role               String  @default("GUEST")
  status             String  @default("ACTIVE")
  language           String  @default("ar-EG")
  activeConversation String?
  metadata           Json?
  schemaVersion      Int     @default(1)
  version            Int     @default(1)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  @@index([userId, chatId])
  @@index([isDeleted])
}

model Attachment {
  id           String  @id @default(cuid())
  fileName     String
  originalName String
  mimeType     String
  size         Int
  provider     String
  providerKey  String  @unique
  url          String?
  metadata     Json?
  moduleId     String?
  entityId     String?
  isEncrypted  Boolean @default(false)

  // Audit fields (BaseEntity pattern)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  @@index([moduleId, entityId])
  @@index([provider])
  @@index([isDeleted])
}

model Setting {
  key         String  @id
  value       String
  description String?

  // Audit fields (Constitution Rule XXVII)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@map("settings")
}
