// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Global Audit Fields (Constitution Rule XXVII)
// These should be copied to every model that needs audit/soft-delete
// until Prisma supports native mixins or global fields.

// User Management Module - User Profile
model UserProfile {
  id          String   @id @default(cuid())
  telegramId  BigInt   @unique
  username    String?
  email       String?
  language    String   @default("ar")
  role        String   @default("USER")

  // Additional identity fields
  nationalId  String?  @unique
  mobileNumber String?
  birthDate   DateTime?
  gender      String?  // 'male' | 'female'
  governorate String?
  countryCode String?  @default("+20")

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  deletedBy   String?

  @@index([telegramId])
  @@index([username])
  @@index([email])
  @@index([role])
  @@index([nationalId])
  @@index([mobileNumber])
  @@index([isDeleted])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userRole  String?
  action    String
  module    String
  targetId  String?
  before    Json?
  after     Json?
  status    String   @default("SUCCESS")
  timestamp DateTime @default(now())

  @@index([module, action])
  @@index([userId])
}

model Session {
  id                 String   @id // Composite of userId:chatId
  userId             String
  chatId             String
  role               String   @default("GUEST")
  status             String   @default("ACTIVE")
  language           String   @default("ar-EG")
  activeConversation String?
  metadata           Json?
  schemaVersion      Int      @default(1)
  version            Int      @default(1)

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
  deletedBy String?

  @@index([userId, chatId])
  @@index([isDeleted])
}

model Attachment {
  id           String  @id @default(cuid())
  fileName     String
  originalName String
  mimeType     String
  size         Int
  provider     String
  providerKey  String  @unique
  url          String?
  metadata     Json?
  moduleId     String?
  entityId     String?
  isEncrypted  Boolean @default(false)

  // Audit fields (BaseEntity pattern)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  @@index([moduleId, entityId])
  @@index([provider])
  @@index([isDeleted])
}

model Setting {
  key         String  @id
  value       String
  description String?

  // Audit fields (Constitution Rule XXVII)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@map("settings")
}

