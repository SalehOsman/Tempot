{
  "name": "@tempot/database",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/database.helper.js",
      "types": "./dist/testing/database.helper.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "db:merge": "tsx scripts/merge-schemas.ts",
    "db:generate": "pnpm db:merge && prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.0.0",
    "@tempot/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "neverthrow": "8.2.0",
    "pg": "^8.20.0",
    "prisma": "^7.0.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.28.0",
    "glob": "^11.1.0",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "testcontainers": "^10.28.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "files": [
    "dist",
    "prisma",
    "prisma.config.ts"
  ]
}
